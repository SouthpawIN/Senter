{
  "manifest_version": "1.0",
  "profiles": ["core", "exec", "graph"],
  "agent": {
    "id": "ajson://ai-toolbox/agents/senter",
    "name": "Senter",
    "version": "1.0.0",
    "description": "Universal AI personal assistant with intelligent routing, web research, and multi-agent orchestration",
    "author": "AI Toolbox",
    "tags": ["universal", "orchestrator", "research", "routing", "personal-assistant"]
  },
  "capabilities": [
    {
      "id": "orchestration",
      "description": "Coordinate multiple agents for comprehensive task completion",
      "schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "User query to process"
          },
          "parallel_processing": {
            "type": "boolean",
            "default": true,
            "description": "Enable parallel research and routing"
          }
        },
        "required": ["query"]
      }
    },
    {
      "id": "context-integration",
      "description": "Combine web research, topic context, and chat history for informed responses",
      "schema": {
        "type": "object",
        "properties": {
          "web_results": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Web search results"
          },
          "topic_context": {
            "type": "string",
            "description": "Topic summary from SENTER.md"
          },
          "chat_history": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Relevant chat history"
          }
        }
      }
    }
  ],
  "tools": [
    {
      "id": "process_query",
      "type": "function",
      "description": "Process user query with parallel research and routing",
      "function": {
        "name": "process_query",
        "description": "Coordinate research and routing for comprehensive query processing",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "User's question or request"
            },
            "include_web_search": {
              "type": "boolean",
              "default": true,
              "description": "Include web research in processing"
            },
            "media_attachments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {"enum": ["image", "audio", "video"]},
                  "path": {"type": "string"}
                }
              },
              "description": "Attached media files"
            }
          },
          "required": ["query"]
        }
      }
    },
    {
      "id": "integrate_context",
      "type": "function",
      "description": "Combine web results, topic context, and chat history",
      "function": {
        "name": "integrate_context",
        "description": "Merge multiple context sources for informed responses",
        "parameters": {
          "type": "object",
          "properties": {
            "web_results": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Results from web search"
            },
            "topic": {
              "type": "string",
              "description": "Selected topic"
            },
            "chat_history": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Relevant chat history items"
            },
            "selected_agent": {
              "type": "string",
              "description": "Agent selected for final response"
            }
          },
          "required": ["web_results", "topic", "selected_agent"]
        }
      }
    }
  ],
  "modalities": {
    "input": ["text", "image", "audio", "video"],
    "output": ["text", "image", "audio"]
  },
  "runtime": {
    "type": "python",
    "version": ">=3.8",
    "entrypoint": "senter.py",
    "dependencies": [
      "torch>=2.0.0",
      "transformers>=4.40.0",
      "accelerate",
      "numpy",
      "soundfile",
      "scipy",
      "Pillow",
      "diffusers",
      "librosa"
    ],
    "environment": {
      "QWEN_OMNI_MODEL": "Models/Qwen2.5-Omni-3B",
      "QWEN_IMAGE_MODEL": "Models/Qwen_Image-Q6_K.gguf",
      "ACE_STEP_MODELS": "ACE-Step"
    },
    "resources": {
      "gpu_memory_mb_min": 16384,
      "cpu_cores_min": 4,
      "memory_mb_min": 8192
    }
  },
  "graph": {
    "nodes": [
      {
        "id": "senter-core",
        "ref": "ajson://ai-toolbox/agents/senter",
        "role": "orchestrator"
      },
      {
        "id": "researcher",
        "ref": "ajson://ai-toolbox/agents/researcher",
        "role": "web-research"
      },
      {
        "id": "router",
        "ref": "ajson://ai-toolbox/agents/router",
        "role": "agent-selection"
      },
      {
        "id": "image-generator",
        "ref": "ajson://ai-toolbox/agents/image-generator",
        "role": "image-generation"
      },
      {
        "id": "music-composer",
        "ref": "ajson://ai-toolbox/agents/music-composer",
        "role": "music-composition"
      },
      {
        "id": "analyzer",
        "ref": "ajson://ai-toolbox/agents/analyzer",
        "role": "content-analysis"
      },
      {
        "id": "summarizer",
        "ref": "ajson://ai-toolbox/agents/summarizer",
        "role": "context-summarization"
      }
    ],
    "edges": [
      {
        "from": "senter-core",
        "to": "researcher",
        "condition": "parallel_processing_enabled and web_search_needed",
        "parallel": true
      },
      {
        "from": "senter-core",
        "to": "router",
        "condition": "parallel_processing_enabled",
        "parallel": true
      },
      {
        "from": "researcher",
        "to": "senter-core",
        "condition": "web_results_available",
        "data_flow": "search_results"
      },
      {
        "from": "router",
        "to": "senter-core",
        "condition": "agent_selected",
        "data_flow": "topic_and_agent"
      },
      {
        "from": "senter-core",
        "to": "image-generator",
        "condition": "selected_agent == 'image-generator'"
      },
      {
        "from": "senter-core",
        "to": "music-composer",
        "condition": "selected_agent == 'music-composer'"
      },
      {
        "from": "senter-core",
        "to": "analyzer",
        "condition": "selected_agent == 'analyzer'"
      },
      {
        "from": "senter-core",
        "to": "summarizer",
        "condition": "context_update_needed",
        "data_flow": "learning_update"
      }
    ],
    "message_envelope": {
      "schema": "https://jsonagents.org/json/schema/message-envelope.json"
    },
    "workflow": {
      "parallel_branches": ["research", "routing"],
      "synchronization_point": "context_integration",
      "data_flows": ["web_results", "topic_context", "chat_history", "agent_selection"]
    }
  },
  "security": {
    "sandbox": "process",
    "network_zone": "trusted",
    "resource_limits": {
      "max_gpu_memory_mb": 24576,
      "max_cpu_memory_mb": 16384,
      "max_execution_time_seconds": 300
    }
  },
  "extensions": {
    "x-senter": {
      "architecture": "Universal Multimodal Agent",
      "core_model": "Qwen2.5-Omni-3B",
      "integrated_tools": ["image_generation", "music_composition", "content_analysis", "creative_writing"],
      "multimodal_capabilities": ["text", "image", "audio", "video"],
      "orchestration_engine": "JSON Agents Graph",
      "performance_profile": "balanced",
      "version": "1.0.0"
    }
  }
}