{
  "manifest_version": "1.0",
  "profiles": ["core", "exec"],
  "agent": {
    "id": "ajson://ai-toolbox/agents/setup",
    "name": "Senter Setup Agent",
    "version": "1.0.0",
    "description": "Automated setup and configuration agent for Senter installation, model management, and system initialization",
    "author": "AI Toolbox",
    "tags": ["setup", "installation", "configuration", "model-management", "system-initialization"]
  },
  "capabilities": [
    {
      "id": "system-setup",
      "description": "Complete Senter system setup and configuration",
      "schema": {
        "type": "object",
        "properties": {
          "install_mode": {
            "type": "string",
            "enum": ["full", "minimal", "custom"],
            "default": "full",
            "description": "Installation mode"
          },
          "auto_download": {
            "type": "boolean",
            "default": true,
            "description": "Automatically download required models"
          }
        }
      }
    },
    {
      "id": "dependency-management",
      "description": "Manage Python dependencies and system requirements",
      "schema": {
        "type": "object",
        "properties": {
          "check_only": {
            "type": "boolean",
            "default": false,
            "description": "Only check dependencies without installing"
          },
          "force_reinstall": {
            "type": "boolean",
            "default": false,
            "description": "Force reinstallation of dependencies"
          }
        }
      }
    },
    {
      "id": "model-management",
      "description": "Download, serve, and manage AI models",
      "schema": {
        "type": "object",
        "properties": {
          "model_type": {
            "type": "string",
            "enum": ["text", "vision", "audio", "all"],
            "default": "all",
            "description": "Type of models to manage"
          },
          "provider": {
            "type": "string",
            "enum": ["huggingface", "auto"],
            "default": "auto",
            "description": "Model provider"
          }
        }
      }
    }
  ],
  "tools": [
    {
      "id": "check_system_requirements",
      "type": "function",
      "description": "Check if system meets Senter requirements",
      "function": {
        "name": "check_system_requirements",
        "description": "Analyze system for required dependencies, hardware, and software",
        "parameters": {
          "type": "object",
          "properties": {
            "detailed": {
              "type": "boolean",
              "default": false,
              "description": "Provide detailed system analysis"
            }
          }
        }
      }
    },
    {
      "id": "install_dependencies",
      "type": "function",
      "description": "Install required Python packages and system dependencies",
      "function": {
        "name": "install_dependencies",
        "description": "Install all required dependencies for Senter operation",
        "parameters": {
          "type": "object",
          "properties": {
            "packages": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Specific packages to install (empty for all)"
            },
            "upgrade": {
              "type": "boolean",
              "default": false,
              "description": "Upgrade existing packages"
            }
          }
        }
      }
    },
    {
      "id": "download_model",
      "type": "function",
      "description": "Download AI models from HuggingFace or other providers",
      "function": {
        "name": "download_model",
        "description": "Download and cache AI models for Senter",
        "parameters": {
          "type": "object",
          "properties": {
            "model_name": {
              "type": "string",
              "description": "Name of the model to download"
            },
            "model_type": {
              "type": "string",
              "enum": ["text", "vision", "audio"],
              "description": "Type of model"
            },
            "provider": {
              "type": "string",
              "default": "huggingface",
              "description": "Model provider"
            }
          },
          "required": ["model_name", "model_type"]
        }
      }
    },
    {
      "id": "start_model_server",
      "type": "function",
      "description": "Start OpenAI-compatible model server",
      "function": {
        "name": "start_model_server",
        "description": "Launch vLLM or llama-cpp server for model serving",
        "parameters": {
          "type": "object",
          "properties": {
            "model_path": {
              "type": "string",
              "description": "Path to the model file"
            },
            "port": {
              "type": "integer",
              "default": 8000,
              "description": "Port to run the server on"
            },
            "server_type": {
              "type": "string",
              "enum": ["vllm", "llama-cpp"],
              "default": "vllm",
              "description": "Type of server to use"
            }
          },
          "required": ["model_path"]
        }
      }
    },
    {
      "id": "initialize_senter",
      "type": "function",
      "description": "Complete Senter system initialization",
      "function": {
        "name": "initialize_senter",
        "description": "Set up all Senter components and configurations",
        "parameters": {
          "type": "object",
          "properties": {
            "reset_config": {
              "type": "boolean",
              "default": false,
              "description": "Reset configuration to defaults"
            },
            "create_topics": {
              "type": "boolean",
              "default": true,
              "description": "Create initial topic structure"
            }
          }
        }
      }
    }
  ],
  "modalities": {
    "input": ["text"],
    "output": ["text"]
  },
  "runtime": {
    "type": "python",
    "version": ">=3.8",
    "entrypoint": "setup_agent.py",
    "dependencies": [
      "torch",
      "transformers",
      "huggingface_hub",
      "psutil",
      "GPUtil",
      "requests",
      "subprocess",
      "pathlib"
    ],
    "environment": {
      "HF_HOME": "/home/sovthpaw/.cache/huggingface",
      "SENTER_ROOT": "/home/sovthpaw/ai-toolbox/Senter"
    },
    "resources": {
      "gpu_memory_mb_min": 1024,
      "cpu_cores_min": 2,
      "memory_mb_min": 2048
    }
  },
  "extensions": {
    "x-setup": {
      "auto_generated": false,
      "capabilities": ["system-setup", "dependency-management", "model-serving"],
      "default_models": {
        "text": "Qwen/Qwen2.5-Omni-3B",
        "vision": "Qwen/Qwen2.5-Omni-3B",
        "audio": "Qwen/Qwen2.5-Omni-3B",
        "music": "ACE-Step/ACE-Step-v1-3.5B"
      },
      "required_packages": [
        "torch>=2.0.0",
        "transformers>=4.40.0",
        "textual",
        "huggingface_hub",
        "psutil",
        "GPUtil"
      ]
    }
  }
}