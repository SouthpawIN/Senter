{
  "manifest_version": "1.0",
  "profiles": ["core", "exec"],
  "agent": {
    "id": "ajson://ai-toolbox/functions/compose_music",
    "name": "Music Composer",
    "version": "1.0.0",
    "description": "Compose music using ACE-Step's advanced music generation pipeline",
    "author": "AI Toolbox",
    "tags": ["music", "composition", "generation", "audio", "ace-step"]
  },
  "capabilities": [
    {
      "id": "compose-music",
      "description": "Generate musical compositions from text descriptions"
    }
  ],
  "tools": [
    {
      "id": "compose_music",
      "type": "function",
      "description": "Compose music based on textual descriptions and parameters",
      "function": {
        "name": "compose_music",
        "description": "Generate musical audio from text prompts using ACE-Step pipeline",
        "parameters": {
          "type": "object",
          "properties": {
            "prompt": {
              "type": "string",
              "description": "Text description of the music to compose"
            },
            "duration": {
              "type": "number",
              "description": "Duration of the composition in seconds",
              "default": 10.0
            },
            "temperature": {
              "type": "number",
              "description": "Creativity/randomness factor (0.0-1.0)",
              "default": 0.8
            },
            "top_k": {
              "type": "integer",
              "description": "Top-k sampling parameter",
              "default": 50
            },
            "top_p": {
              "type": "number",
              "description": "Top-p sampling parameter",
              "default": 0.9
            },
            "guidance_scale": {
              "type": "number",
              "description": "How closely to follow the prompt",
              "default": 3.0
            }
          },
          "required": ["prompt"]
        }
      }
    }
  ],
  "modalities": {
    "input": ["text"],
    "output": ["text", "audio"]
  },
  "runtime": {
    "type": "python",
    "version": ">=3.8",
    "entrypoint": "compose_music.py",
    "dependencies": [
      "torch",
      "loguru",
      "tqdm",
      "numpy"
    ],
    "environment": {
      "ACE_STEP_PATH": "../ACE-Step"
    },
    "resources": {
      "gpu_memory_mb_min": 4096,
      "cpu_cores_min": 2,
      "memory_mb_min": 4096
    }
  },
  "extensions": {
    "x-function": {
      "auto_generated": true,
      "model": "ACE-Step",
      "capabilities": ["text-to-music", "music-generation", "audio-synthesis"]
    }
  }
}