{
  "manifest_version": "1.0",
  "profiles": ["core", "exec"],
  "agent": {
    "id": "ajson://ai-toolbox/agents/summarizer",
    "name": "Qwen Omni Summarizer",
    "version": "1.0.0",
    "description": "Advanced text summarization using Qwen2.5-Omni with multimodal support",
    "author": "AI Toolbox",
    "tags": ["summarization", "nlp", "multimodal", "qwen-omni"]
  },
  "capabilities": [
    {
      "id": "summarization",
      "description": "Generate concise summaries of text content",
      "schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text content to summarize"
          },
          "max_length": {
            "type": "integer",
            "default": 200,
            "minimum": 50,
            "maximum": 1000,
            "description": "Maximum summary length in words"
          },
          "style": {
            "type": "string",
            "default": "concise",
            "enum": ["concise", "detailed", "bullet-points", "executive"],
            "description": "Summary style"
          },
          "focus": {
            "type": "string",
            "description": "Specific aspect to focus on (optional)"
          }
        },
        "required": ["text"]
      }
    },
    {
      "id": "multimodal-summarization",
      "description": "Summarize content combining text, images, and audio",
      "schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Primary text content"
          },
          "image_path": {
            "type": "string",
            "description": "Optional image to include in summary"
          },
          "audio_path": {
            "type": "string",
            "description": "Optional audio to include in summary"
          },
          "max_length": {
            "type": "integer",
            "default": 300,
            "description": "Maximum summary length"
          }
        },
        "required": ["text"]
      }
    }
  ],
  "tools": [
    {
      "id": "summarize_text",
      "type": "function",
      "description": "Generate a summary of text content",
      "function": {
        "name": "summarize_text",
        "description": "Create a concise summary of the provided text",
        "parameters": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "The text to summarize"
            },
            "max_words": {
              "type": "integer",
              "default": 150,
              "description": "Maximum number of words in summary"
            },
            "style": {
              "type": "string",
              "default": "concise",
              "enum": ["concise", "detailed", "key-points"],
              "description": "Summary style preference"
            }
          },
          "required": ["text"]
        }
      }
    },
    {
      "id": "summarize_document",
      "type": "function",
      "description": "Summarize longer documents with structure preservation",
      "function": {
        "name": "summarize_document",
        "description": "Create a structured summary of a document",
        "parameters": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "description": "Document content to summarize"
            },
            "sections": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Key sections to focus on"
            },
            "include_key_points": {
              "type": "boolean",
              "default": true,
              "description": "Include key points in summary"
            }
          },
          "required": ["content"]
        }
      }
    }
  ],
  "modalities": {
    "input": ["text", "image", "audio"],
    "output": ["text"]
  },
  "runtime": {
    "type": "python",
    "version": ">=3.8",
    "entrypoint": "qwen25_omni_agent.py",
    "dependencies": [
      "torch>=2.0.0",
      "transformers>=4.40.0",
      "accelerate",
      "numpy",
      "soundfile",
      "scipy"
    ],
    "environment": {
      "MODEL_PATH": "/home/sovthpaw/Models/Qwen2.5-Omni-3B"
    },
    "resources": {
      "gpu_memory_mb_min": 8192,
      "cpu_cores_min": 2,
      "memory_mb_min": 4096
    }
  },
  "extensions": {
    "x-summarization": {
      "model": "Qwen2.5-Omni-3B",
      "capabilities": ["text-summarization", "multimodal-summarization"],
      "supported_languages": ["en", "zh", "multilingual"],
      "max_input_length": 32768,
      "summary_quality": "high"
    }
  }
}